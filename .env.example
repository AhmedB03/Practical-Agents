# Copy to .env and fill in to enable the Azure production path.
# With NOTHING set, the project runs fully locally (FAISS + local embeddings).

# --- Azure OpenAI (chat + judge + embeddings) ---
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-06-01
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_JUDGE_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
# EMBED_DIM=1536

# --- Azure AI Search (vector store) — optional; else local FAISS ---
# AZURE_SEARCH_ENDPOINT=https://<resource>.search.windows.net
# AZURE_SEARCH_API_KEY=
# AZURE_SEARCH_INDEX=practical-agents

# --- Or Groq (free tier, no card; OpenAI-compatible chat + local embeddings) ---
# GROQ_API_KEY=
# GROQ_CHAT_MODEL=openai/gpt-oss-20b
# GROQ_JUDGE_MODEL=openai/gpt-oss-20b

# --- Or plain OpenAI ---
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Retrieval knobs (optional overrides; ablation harness sets these itself) ---
# TOP_K=5
# USE_RERANKER=false
# CHUNK_TOKENS=220
# CHUNK_OVERLAP=40
# CORPUS_DIR=corpus
